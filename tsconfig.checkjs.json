{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext"
  },
  "include": [
    "config/firebase.js",
    "utils/logger.js",
    "utils/plannerStorage.js"
  ],
  "exclude": ["node_modules", "android", "ios"]
}
