{
  "name": "ctu-academic-task-manager",
  "main": "index.js",
  "version": "1.0.3",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "migrate-schedules": "node ./scripts/migrate-schedules.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:update": "expo export --output-dir dist --source-maps --dump-assetmap --platform ios --platform android --clear --no-bytecode",
    "export:update:android": "expo export --output-dir dist --source-maps --dump-assetmap --platform android --clear --no-bytecode",
    "update:publish:dist": "eas update --skip-bundler --input-dir dist",
    "lint": "eslint app components context hooks utils features config --ignore-pattern '!**/node_modules/**'",
    "typecheck:js": "tsc -p tsconfig.checkjs.json",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "check": "npm run typecheck:js && npm run lint && npm run test:ci"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-native-picker/picker": "2.11.1",
    "@sentry/node": "^10.49.0",
    "@sentry/react-native": "~7.2.0",
    "eslint-config-expo": "~10.0.0",
    "expo": "~54.0.25",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.9",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.9",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.15",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.11",
    "firebase": "^10.14.1",
    "jest-expo": "~54.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "jest",
        "@types/jest"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": ["@notifee/react-native"]
      }
    }
  },
  "private": true
}
