{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "expo-env.d.ts",
    "app/layout.js",
    "app/(admin)/home.js",
    "app/(tabs)/index.js",
    ".expo/types/**/*.ts"
  ],
  "exclude": ["node_modules", "node_modules/expo-notifications"]
}
